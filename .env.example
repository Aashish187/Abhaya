# Frontend (Expo) environment variables
# Copy this to .env and fill in your local development values.

# Preferred backend base URL for the app.
# Use your machine LAN IP when testing on a physical device.
EXPO_PUBLIC_API_BASE_URL=http://your_local_ip:5000/api

# Compatibility aliases used by some screens/services.
EXPO_PUBLIC_BACKEND_URL=http://your_local_ip:5000
EXPO_PUBLIC_BACKEND_API_URL=http://your_local_ip:5000/api
EXPO_PUBLIC_API_URL=http://your_local_ip:5000/api

# Cloudinary (optional for incident evidence uploads)
EXPO_PUBLIC_CLOUDINARY_UPLOAD_URL=https://api.cloudinary.com/v1_1/your_cloud_name/video/upload
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset
