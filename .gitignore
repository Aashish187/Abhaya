# Environment / secrets
# =========================
.env
.env.*
.env*.local
*.env

backend/.env
backend/.env.*
backend/.env*.local

# Keep example env files
!.env.example
!backend/.env.example

# Firebase / service keys / private keys
serviceAccountKey.json
backend/serviceAccountKey.json
**/serviceAccountKey.json
*.pem
*.key
*.jks
*.p8
*.p12
*.mobileprovision

