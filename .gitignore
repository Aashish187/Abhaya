# =========================
.expo/
.expo-shared/
expo-env.d.ts
web-build/
dist/

# Generated native folders
/ios/
/android/

# =========================
# Metro / React Native cache
# =========================
.metro-health-check*
.metro-cache/
.watchmanconfig

# =========================
# Backend runtime files
